        "current_day": {
          "name": "Current day",
          "description": "Day for the exclusion schedule you want to change."
        },
        "current_start": {
          "name": "Current start",
          "description": "Start time for the exclusion schedule you want to change."
        },
        "day": {
          "name": "Day",
          "description": "New day of week for the exclusion schedule entry."
        },
        "start": {
          "name": "Start",
          "description": "New start time in HH:MM format."
        },
        "duration": {
          "name": "Duration",
          "description": "New duration in minutes."
        },
        "reason": {
          "name": "Reason",
          "description": "Reason for the exclusion schedule entry."
        }
      }
    },
    "delete_exclusion_schedule": {
      "name": "Delete exclusion schedule",
      "description": "Delete an exclusion schedule entry from auto schedule.",
      "fields": {
        "day": {
          "name": "Day",
          "description": "Day for the exclusion schedule you want to delete."
        },
        "start": {
          "name": "Start",
          "description": "Use this if the selected day has more than one exclusion schedule and you need to choose one by time."
        }
      }
    }
