  "services": {
    "ots": {
      "name": "Start one-time schedule",
      "description": "Start a one-time mowing schedule if the mower supports it.",
      "fields": {
        "boundary": {
          "name": "Boundary",
          "description": "Whether to include a boundary cut."
        },
        "runtime": {
          "name": "Run time",
          "description": "Run time in minutes."
        }
      }
    },
    "add_schedule": {
      "name": "Add schedule",
      "description": "Add a mowing schedule entry.",
      "fields": {
        "days": {
          "name": "Days",
          "description": "Days of week for the new schedule entry."
        },
        "start": {
          "name": "Start",
          "description": "Start time in HH:MM format."
        },
        "duration": {
          "name": "Duration",
          "description": "Duration in minutes."
        },
        "boundary": {
          "name": "Boundary",
          "description": "Whether boundary cutting should be enabled for this entry."
        }
      }
    },
    "edit_schedule": {
      "name": "Edit schedule",
      "description": "Replace an existing mowing schedule entry.",
      "fields": {
        "current_day": {
          "name": "Current day",
          "description": "Day for the schedule you want to change."
        },
        "current_start": {
          "name": "Current start",
          "description": "Use this if the selected day has more than one schedule and you need to choose one by time."
        },
        "day": {
          "name": "Day",
          "description": "New day of week for the schedule entry."
        },
        "start": {
          "name": "Start",
          "description": "New start time in HH:MM format."
        },
        "duration": {
          "name": "Duration",
          "description": "New duration in minutes."
        },
        "boundary": {
          "name": "Boundary",
          "description": "Whether boundary cutting should be enabled for this entry."
        }
      }
    },
    "delete_schedule": {
      "name": "Delete schedule",
      "description": "Delete an existing mowing schedule entry.",
      "fields": {
        "all_schedules": {
          "name": "All schedules",
          "description": "Delete all schedules for this mower in one call."
        },
        "day": {
          "name": "Day",
          "description": "Day for the schedule you want to delete."
        },
        "start": {
          "name": "Start",
          "description": "Use this if the selected day has more than one schedule and you need to choose one by time."
        }
      }
    },
    "set_nutrition": {
      "name": "Set nutrition",
      "description": "Set auto-schedule nutrition values.",
      "fields": {
        "n": {
          "name": "Nitrogen (N)",
          "description": "Nitrogen value for auto-schedule nutrition."
        },
        "p": {
          "name": "Phosphorus (P)",
          "description": "Phosphorus value for auto-schedule nutrition."
        },
        "k": {
          "name": "Potassium (K)",
          "description": "Potassium value for auto-schedule nutrition."
        }
      }
    },
    "clear_nutrition": {
      "name": "Clear nutrition",
      "description": "Clear auto-schedule nutrition values."
    },
    "set_exclusion_day": {
      "name": "Set exclusion day",
      "description": "Exclude or include one weekday in auto schedule.",
      "fields": {
        "day": {
          "name": "Day",
          "description": "Day to update in the exclusion scheduler."
        },
        "exclude_day": {
          "name": "Exclude day",
          "description": "Whether the selected day should be fully excluded."
        }
      }
    },
